<%- include('partials/header', { title: post.title }) %>

<a href="/" class="back-link">← Back to posts</a>

<br><br>

<div class="post-full">
    <h1><%= post.title %></h1>
    <span class="post-date"><%= post.created_at.toDateString() %></span>

    <hr>

    <p class="post-content"><%= post.content %></p>

    <% if (user) { %>
        <hr>
        <a href="/posts/<%= post.id %>/edit" class="btn">Edit</a>
        <form action="/posts/<%= post.id %>/delete" method="POST" style="display: inline;">
            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this post?')">Delete</button>
        </form>
    <% } %>
</div>

<%- include('partials/footer') %>
